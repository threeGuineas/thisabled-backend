# compose가 db/redis 컨테이너에 주입하는 자격증명. openssl rand -base64 24 로 생성 권장.
POSTGRES_PASSWORD=change-me-openssl-rand-base64-24
REDIS_PASSWORD=change-me-openssl-rand-base64-24
# app 접속 URL — 위 비밀번호와 값이 일치해야 함(URL-safe 문자만 사용).
DATABASE_URL=postgresql+asyncpg://thisabled:change-me-openssl-rand-base64-24@db:5432/thisabled
REDIS_URL=redis://:change-me-openssl-rand-base64-24@redis:6379/0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false
STORAGE_BACKEND=local
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10
OPENAI_API_KEY=
VISION_MODEL=gpt-4o

# ── v2.1 ──────────────────────────────────────────────
# OAuth: dev는 mock(true). 카카오/구글 실키 발급 후 false로 전환하고 키 입력.
OAUTH_MOCK=true
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000
# AI 모델 서버 (compose 내부 네트워크)
SAFETY_MODEL_URL=http://safety-model:9001
MATCH_MODEL_URL=http://match-model:9002
# 실모델 서버(safety/match)가 HF private repo에서 모델 다운로드에 사용. mock만 쓸 땐 비워둬도 됨.
HF_TOKEN=
